// Comentário lembrando a fórmula matemática: Peso dividido pela altura ao quadrado
//imc = peso/ altura * altura

// Solicita que o usuário informe o peso (massa corporal)
Console.WriteLine($"por favor insira sua massa corporal:");

// Lê a entrada, tenta converter para float e armazena na variável 'peso'
float.TryParse(Console.ReadLine(), out float peso);

// Solicita que o usuário informe a altura
Console.WriteLine($"por favor insira sua altura:");

// Lê a entrada, tenta converter para float e armazena na variável 'altura'
float.TryParse(Console.ReadLine(), out float altura);

// Calcula o IMC usando a fórmula: peso dividido pela altura elevada à potência 2
double massa = peso / (Math.Pow(altura, 2));

// Verifica se o resultado está entre 0 e 15.9 (Magreza Severa)
if ( massa >= 0 && massa < 16 )
{
    Console.WriteLine("você está com magreza severa, procure um medico");
}
// Verifica se o resultado está entre 16 e 16.8 (Magreza Moderada)
else if ( massa >= 16 && massa < 16.9 )
{
    Console.WriteLine("você está com magreza moderada");
}
// Verifica se o resultado está entre 17 e 18.4 (Magreza Leve)
else if (massa >= 17 && massa < 18.5)
{
    Console.WriteLine("você está com magreza leve");
}
// Verifica se o resultado está entre 18.6 e 24.8 (Peso Ideal)
else if (massa >= 18.6 && massa < 24.9)
{
    Console.WriteLine("você está no peso ideal");
}
// Verifica se o resultado está entre 25 e 29.8 (Sobrepeso)
else if (massa >= 25 && massa < 29.9)
{
    Console.WriteLine("você está com sobrepeso");
}
// Verifica se o resultado está entre 30 e 34.8 (Obesidade Grau I)
else if (massa >= 30 && massa < 34.9)
{
    Console.WriteLine("você está com obesidade grau I");
}

//**************************** conversor de moeda *********************************
// Declara as variáveis inteiras 'saldo' e 'termos' que serão usadas no primeiro laço
int saldo, termos;

// Solicita que o usuário informe a quantidade de termos (repetições) que deseja
Console.WriteLine("Digite o n° de termos: ");

// Lê a entrada, trata possíveis nulos com '!' e tenta converter para inteiro na variável 'termos'
int.TryParse(Console.ReadLine()!, out termos);

// Solicita que o usuário informe o valor do saldo inicial
Console.WriteLine("digite o n° do saldo: ");

// Tenta converter a entrada do usuário para a variável inteira 'saldo'
int.TryParse(Console.ReadLine()!, out saldo);

// Exibe o número zero como ponto de partida da sequência
Console.WriteLine("0;");

// Inicia um laço que vai de 1 até o número de termos definido pelo usuário
for (int i = 1; i <= termos; i++) 
{
    // Exibe o resultado da multiplicação do saldo pelo índice atual do laço
    Console.WriteLine($"{saldo * i};");
}

// Exibe uma mensagem padrão de boas-vindas do C#
Console.WriteLine("Hello, World!");

// Declara variáveis do tipo float para valores monetários e uma para armazenar o resultado final
float reais, conReais, resultado;

// Declara uma variável inteira para armazenar a opção de menu escolhida pelo usuário
int escolha;

// Exibe o título do programa conversor de moedas
Console.WriteLine("************* conversor de moedas *************");

// Solicita ao usuário o valor em Reais (R$) que ele possui
Console.WriteLine("digite o valor em reais: ");

// Lê a entrada e tenta converter para float na variável 'reais'
float.TryParse(Console.ReadLine()!, out reais);

// Exibe as opções de destino para a conversão (Dólar ou Libras)
Console.WriteLine("\nDigite 1 para converter para dólar\n" +
"Digite 2 para converter para libras");

// Pede para o usuário digitar a opção desejada
Console.WriteLine("Digite: ");

// Tenta converter a opção escolhida para a variável 'escolha'
int.TryParse(Console.ReadLine()!, out escolha); 

// Inicia a estrutura de decisão baseada na escolha do usuário
switch (escolha)
{
    // Caso o usuário tenha digitado 1 (Dólar)
    case 1:
        // Pede a cotação atual do dólar turismo
        Console.WriteLine("digite o valor de dólar turismo: ");
        // Lê a entrada, troca pontos por vírgulas (para evitar erro de formato) e converte para float
        float.TryParse(Console.ReadLine()!.Replace(".",","), out conReais);
        // Multiplica a quantidade de reais pela cotação informada
        resultado = reais * conReais;
        // Exibe o cálculo e o resultado final formatado
        Console.WriteLine($"R${reais} X U${conReais} = R${resultado}");
        break;

    // Caso o usuário digite qualquer valor que não seja 1 ou 2
    default:
        // Informa que a opção selecionada não existe no menu
        Console.WriteLine("opção inválida");
        break;

    // Caso o usuário tenha digitado 2 (Libras)
    case 2:
        // Pede a cotação ou valor em libras (o texto diz dólar, mas a lógica é para libras)
        Console.WriteLine("digite o valor de dólar turismo: ");
        // Lê a entrada, ajusta a pontuação decimal e converte para float
        float.TryParse(Console.ReadLine()!.Replace(".", ","), out conReais);
        // Multiplica o valor informado pela taxa fixa de 6.85 (f indica que o número é float)
        reais = conReais * 6.85f; 
        // Exibe o cálculo da conversão de Libras para Reais
        Console.WriteLine($"£${conReais} X 6.85 = R${reais} ");
        break;
}
